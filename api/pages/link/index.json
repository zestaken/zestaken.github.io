{"title":"link","uid":"80287ad235cdbcc4f9be0777b0968a6a","text":" .friends-group .friend-content { display: flex; display: flex; flex-wrap: wrap; justify-content: center; margin: -8px; border-radius: 8px; ...","date":"2021-05-29T08:40:01.000Z","updated":"2021-10-07T08:10:36.824Z","comments":true,"path":"api/pages/link/index.json","covers":null,"excerpt":"","content":"<div id=\"links\">\r\n<!-- 友情链接css样式 -->\r\n<style>\r\n    .friends-group .friend-content {\r\n  display: flex;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  justify-content: center;\r\n  margin: -8px;\r\n  border-radius: 8px;\r\n  justify-content: flex-start;\r\n  align-items: flex-start;\r\n  line-height: 1.3;\r\n}\r\n.friends-group .friend-content .friend-card {\r\n  display: flex;\r\n  border-radius: 4px;\r\n  box-shadow: 0 1px 2px 0 rgba(0,0,0,0.1);\r\n  padding: 8px 0;\r\n  margin: 8px;\r\n  margin-top: calc(2.25 * 16px + 32px);\r\n  color: rgba(85,85,85,0.65);\r\n  background: #f6f6f6;\r\n  justify-content: flex-start;\r\n  align-content: flex-start;\r\n  flex-direction: column;\r\n  width: calc(100% / 4 - 16px);\r\n}\r\n@media screen and (max-width: 1024px) {\r\n  .friends-group .friend-content .friend-card {\r\n    width: calc(100% / 4 - 16px);\r\n  }\r\n}\r\n@media screen and (max-width: 768px) {\r\n  .friends-group .friend-content .friend-card {\r\n    width: calc(100% / 3 - 16px);\r\n  }\r\n}\r\n@media screen and (max-width: 500px) {\r\n  .friends-group .friend-content .friend-card {\r\n    width: calc(100% / 2 - 16px);\r\n  }\r\n}\r\n.friends-group .friend-content .friend-card:hover .friend-left .avatar {\r\n  transform: scale(1.2) rotate(12deg);\r\n  box-shadow: 0 2px 4px 0 rgba(0,0,0,0.1), 0 4px 8px 0 rgba(0,0,0,0.1), 0 8px 16px 0 rgba(0,0,0,0.1);\r\n}\r\n.friends-group .friend-content .friend-card .friend-left {\r\n  display: flex;\r\n  align-self: center;\r\n}\r\n.friends-group .friend-content .friend-card .friend-left .avatar {\r\n  width: 64px;\r\n  height: 64px;\r\n  transition: all 0.28s ease;\r\n  -moz-transition: all 0.28s ease;\r\n  -webkit-transition: all 0.28s ease;\r\n  -o-transition: all 0.28s ease;\r\n  box-shadow: 0 1px 2px 0 rgba(0,0,0,0.1);\r\n  margin: 16px 8px 4px 8px;\r\n  margin-top: calc(-1.25 * 16px - 32px);\r\n  border-radius: 100%;\r\n  border: 2px solid #fff;\r\n  background: #fff;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right {\r\n  margin: 4px 8px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  text-align: center;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p {\r\n  text-align: center;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right .friend-tags-wrapper {\r\n  transition: all 0.28s ease;\r\n  -moz-transition: all 0.28s ease;\r\n  -webkit-transition: all 0.28s ease;\r\n  -o-transition: all 0.28s ease;\r\n  margin-left: -2px;\r\n  word-break: break-all;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p {\r\n  margin: 0;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p.friend-name {\r\n  font-size: 0.8125rem;\r\n  padding-top: 4px;\r\n  font-weight: 700;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p.tags {\r\n  font-size: 0.75rem;\r\n  display: inline;\r\n  background: 0 0;\r\n  overflow-wrap: break-word;\r\n  padding-right: 4px;\r\n}\r\n</style>\r\n<pre><code>&lt;div class=&quot;friends-group&quot;&gt;\r\n    &lt;h1 class=&quot;friend-header&quot;&gt;\r\n        &lt;i class=&quot;fas fa-user-tie fa-fw&quot; aria-hidden=&quot;true&quot;&gt;&lt;/i&gt;\r\n        友情链接\r\n    &lt;/h1&gt;\r\n    &lt;div class=&quot;friend-content&quot;&gt;\r\n        &#123;% for link in site.data.links %&#125;\n            <!-- 友情链接卡片 -->\n                <a class=\"friend-card\" style=\"background:#ECB446; color:#fff\" target=\"_blank\" rel=\"noopener noreferrer\" href=\"&#123;&#123; link.site &#125;&#125;\">\n                    <div class=\"friend-left\">\n                        <img class=\"avatar\" src=\"&#123;&#123; link.avatar &#125;&#125;\" data-original=\"&#123;&#123; link.avatar &#125;&#125;\">\n                    </div>\n                    <div class=\"friend-right\">\n                        <p class=\"friend-name\">&#123;&#123; link.name &#125;&#125;</p>\n                        <div class=\"friend-tags-wrapper\">\n                            <p class=\"tags\">&#123;&#123; link.info &#125;&#125;</p>\n                        </div>\n                    </div>\n                </a>\n            &#123;% endfor %&#125;\r\n    &lt;/div&gt;\r\n&lt;/div&gt;          </code></pre>\r\n</div>\r\n<h1 id=\"我的链接\">我的链接</h1>\r\n<pre class=\"line-numbers language-yml\" data-language=\"yml\"><code class=\"language-yml\">- name: ZestJourney\n  link: https:&#x2F;&#x2F;www.zestaken.top\n  avatar: https:&#x2F;&#x2F;gitee.com&#x2F;zhangjie0524&#x2F;picgo&#x2F;raw&#x2F;master&#x2F;20210529191900.jpg\n  descr: 吾好梦中读书~</code></pre>\r\n<ul>\r\n<li>欢迎留言互加友链~</li>\r\n</ul>\r\n","count_time":{"symbolsCount":"3.7k","symbolsTime":"3 mins."},"toc":"<ol class=\"toc\"><li class=\"toc-item toc-level-1\"><a class=\"toc-link\" href=\"#%E6%88%91%E7%9A%84%E9%93%BE%E6%8E%A5\"><span class=\"toc-text\">我的链接</span></a></li></ol>"}