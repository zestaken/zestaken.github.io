{"title":"link","uid":"80287ad235cdbcc4f9be0777b0968a6a","text":" .friends-group .friend-content { display: flex; display: flex; flex-wrap: wrap; justify-content: center; margin: -8px; border-radius: 8px; ...","date":"2021-05-29T08:40:01.000Z","updated":"2021-10-18T09:45:50.971Z","comments":true,"path":"api/pages/link/index.json","covers":[],"excerpt":"","content":"<div id=\"links\">\r\n<!-- 友情链接css样式 -->\r\n<style>\r\n    .friends-group .friend-content {\r\n  display: flex;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  justify-content: center;\r\n  margin: -8px;\r\n  border-radius: 8px;\r\n  justify-content: flex-start;\r\n  align-items: flex-start;\r\n  line-height: 1.3;\r\n}\r\n.friends-group .friend-content .friend-card {\r\n  display: flex;\r\n  border-radius: 4px;\r\n  box-shadow: 0 1px 2px 0 rgba(0,0,0,0.1);\r\n  padding: 8px 0;\r\n  margin: 8px;\r\n  margin-top: calc(2.25 * 16px + 32px);\r\n  color: rgba(85,85,85,0.65);\r\n  background: #f6f6f6;\r\n  justify-content: flex-start;\r\n  align-content: flex-start;\r\n  flex-direction: column;\r\n  width: calc(100% / 4 - 16px);\r\n}\r\n@media screen and (max-width: 1024px) {\r\n  .friends-group .friend-content .friend-card {\r\n    width: calc(100% / 4 - 16px);\r\n  }\r\n}\r\n@media screen and (max-width: 768px) {\r\n  .friends-group .friend-content .friend-card {\r\n    width: calc(100% / 3 - 16px);\r\n  }\r\n}\r\n@media screen and (max-width: 500px) {\r\n  .friends-group .friend-content .friend-card {\r\n    width: calc(100% / 2 - 16px);\r\n  }\r\n}\r\n.friends-group .friend-content .friend-card:hover .friend-left .avatar {\r\n  transform: scale(1.2) rotate(12deg);\r\n  box-shadow: 0 2px 4px 0 rgba(0,0,0,0.1), 0 4px 8px 0 rgba(0,0,0,0.1), 0 8px 16px 0 rgba(0,0,0,0.1);\r\n}\r\n.friends-group .friend-content .friend-card .friend-left {\r\n  display: flex;\r\n  align-self: center;\r\n}\r\n.friends-group .friend-content .friend-card .friend-left .avatar {\r\n  width: 64px;\r\n  height: 64px;\r\n  transition: all 0.28s ease;\r\n  -moz-transition: all 0.28s ease;\r\n  -webkit-transition: all 0.28s ease;\r\n  -o-transition: all 0.28s ease;\r\n  box-shadow: 0 1px 2px 0 rgba(0,0,0,0.1);\r\n  margin: 16px 8px 4px 8px;\r\n  margin-top: calc(-1.25 * 16px - 32px);\r\n  border-radius: 100%;\r\n  border: 2px solid #fff;\r\n  background: #fff;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right {\r\n  margin: 4px 8px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  text-align: center;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p {\r\n  text-align: center;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right .friend-tags-wrapper {\r\n  transition: all 0.28s ease;\r\n  -moz-transition: all 0.28s ease;\r\n  -webkit-transition: all 0.28s ease;\r\n  -o-transition: all 0.28s ease;\r\n  margin-left: -2px;\r\n  word-break: break-all;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p {\r\n  margin: 0;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p.friend-name {\r\n  font-size: 0.8125rem;\r\n  padding-top: 4px;\r\n  font-weight: 700;\r\n}\r\n.friends-group .friend-content .friend-card .friend-right p.tags {\r\n  font-size: 0.75rem;\r\n  display: inline;\r\n  background: 0 0;\r\n  overflow-wrap: break-word;\r\n  padding-right: 4px;\r\n}\r\n</style>\r\n<div class=\"friends-group\">\r\n<h1 class=\"friend-header\">\r\n<i class=\"fas fa-user-tie fa-fw\" aria-hidden=\"true\"></i> 友情链接\r\n</h1>\r\n<div class=\"friend-content\">\r\n\n<!-- 友情链接卡片 -->\n<a class=\"friend-card\" style=\"background:#ECB446; color:#fff\" target=\"_blank\" rel=\"noopener noreferrer\" href=\"https://novernight.github.io/\">\n<div class=\"friend-left\">\n<img class=\"avatar\" src=\"https://zjpicture.oss-cn-beijing.aliyuncs.com/img/20210918124211.png\" data-original=\"https://zjpicture.oss-cn-beijing.aliyuncs.com/img/20210918124211.png\">\n</div>\n<div class=\"friend-right\">\n<p class=\"friend-name\">Novernight</p>\n<div class=\"friend-