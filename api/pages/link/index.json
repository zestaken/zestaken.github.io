{"title":"link","uid":"80287ad235cdbcc4f9be0777b0968a6a","text":" .friends-group .friend-content { display: flex; display: flex; flex-wrap: wrap; justify-content: center; margin: -8px; border-radius: 8px; ...","date":"2021-05-29T08:40:01.000Z","updated":"2021-10-06T07:27:26.020Z","comments":true,"path":"api/pages/link/index.json","covers":[],"excerpt":"","content":"<div id=\"links\">\n <!-- 友情链接css样式 -->\n<style>\n    .friends-group .friend-content {\n  display: flex;\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: center;\n  margin: -8px;\n  border-radius: 8px;\n  justify-content: flex-start;\n  align-items: flex-start;\n  line-height: 1.3;\n}\n.friends-group .friend-content .friend-card {\n  display: flex;\n  border-radius: 4px;\n  box-shadow: 0 1px 2px 0 rgba(0,0,0,0.1);\n  padding: 8px 0;\n  margin: 8px;\n  margin-top: calc(2.25 * 16px + 32px);\n  color: rgba(85,85,85,0.65);\n  background: #f6f6f6;\n  justify-content: flex-start;\n  align-content: flex-start;\n  flex-direction: column;\n  width: calc(100% / 4 - 16px);\n}\n@media screen and (max-width: 1024px) {\n  .friends-group .friend-content .friend-card {\n    width: calc(100% / 4 - 16px);\n  }\n}\n@media screen and (max-width: 768px) {\n  .friends-group .friend-content .friend-card {\n    width: calc(100% / 3 - 16px);\n  }\n}\n@media screen and (max-width: 500px) {\n  .friends-group .friend-content .friend-card {\n    width: calc(100% / 2 - 16px);\n  }\n}\n.friends-group .friend-content .friend-card:hover .friend-left .avatar {\n  transform: scale(1.2) rotate(12deg);\n  box-shadow: 0 2px 4px 0 rgba(0,0,0,0.1), 0 4px 8px 0 rgba(0,0,0,0.1), 0 8px 16px 0 rgba(0,0,0,0.1);\n}\n.friends-group .friend-content .friend-card .friend-left {\n  display: flex;\n  align-self: center;\n}\n.friends-group .friend-content .friend-card .friend-left .avatar {\n  width: 64px;\n  height: 64px;\n  transition: all 0.28s ease;\n  -moz-transition: all 0.28s ease;\n  -webkit-transition: all 0.28s ease;\n  -o-transition: all 0.28s ease;\n  box-shadow: 0 1px 2px 0 rgba(0,0,0,0.1);\n  margin: 16px 8px 4px 8px;\n  margin-top: calc(-1.25 * 16px - 32px);\n  border-radius: 100%;\n  border: 2px solid #fff;\n  background: #fff;\n}\n.friends-group .friend-content .friend-card .friend-right {\n  margin: 4px 8px;\n  display: flex;\n  flex-direction: column;\n  text-align: center;\n}\n.friends-group .friend-content .friend-card .friend-right p {\n  text-align: center;\n}\n.friends-group .friend-content .friend-card .friend-right .friend-tags-wrapper {\n  transition: all 0.28s ease;\n  -moz-transition: all 0.28s ease;\n  -webkit-transition: all 0.28s ease;\n  -o-transition: all 0.28s ease;\n  margin-left: -2px;\n  word-break: break-all;\n}\n.friends-group .friend-content .friend-card .friend-right p {\n  margin: 0;\n}\n.friends-group .friend-content .friend-card .friend-right p.friend-name {\n  font-size: 0.8125rem;\n  padding-top: 4px;\n  font-weight: 700;\n}\n.friends-group .friend-content .friend-card .friend-right p.tags {\n  font-size: 0.75rem;\n  display: inline;\n  background: 0 0;\n  overflow-wrap: break-word;\n  padding-right: 4px;\n}\n</style>\n    <div class=\"friends-group\">\n        <h1 class=\"friend-header\">\n            <i class=\"fas fa-user-tie fa-fw\" aria-hidden=\"true\"></i>\n            友情链接\n        </h1>\n        <div class=\"friend-content\">\n            \n            <!-- 友情链接卡片 -->\n                <a class=\"friend-card\" style=\"background:#12CCCF ; color:#CFBBC9\" target=\"_blank\" rel=\"noopener noreferrer\" href=\"https://novernight.github.io/\">\n                    <div class=\"friend-left\">\n                        <img class=\"avatar\" src=\"https://zjpicture.oss-cn-beijing.aliyuncs.com/img/20210918124211.png\" data-original=\"https://zjpicture.oss-cn-beijing.aliyuncs.com/img/20210918124211.png\">\n                    </div>\n                    <div class=\"friend-right\">\n                        <p class=\"friend-name\">Novernight</p>\n                    