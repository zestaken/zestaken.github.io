\r\n</td>\r\n<td>\r\n17\r\n</td>\r\n<td>\r\n18\r\n</td>\r\n<td>\r\n19\r\n</td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n</div>\r\n<ul>\r\n<li>再生成一个随机排列的5位数组，用于按这个顺序打乱矩阵</li>\r\n</ul>\r\n<pre class=\"line-numbers language-python\" data-language=\"python\"><code class=\"language-python\">sampler &#x3D; np.random.permutation(5)\nsampler</code></pre>\r\n<pre><code>array([3, 2, 0, 4, 1])</code></pre>\r\n<ul>\r\n<li>按照sampler排列的顺序排列矩阵，因为sampler是随机排列的，所以实现了打乱矩阵，随机采样的效果</li>\r\n<li><code>take()</code>函数可以实现按照特定序列实现矩阵的行调换的功能</li>\r\n</ul>\r\n<pre class=\"line-numbers language-python\" data-language=\"python\"><code class=\"language-python\">df.take(sampler)</code></pre>\r\n<div>\r\n<style scoped>\r\n    .dataframe tbody tr th:only-of-type {\r\n        vertical-align: middle;\r\n    }\r\n\r\n    .dataframe tbody tr th {\r\n        vertical-align: top;\r\n    }\r\n    \r\n    .dataframe thead th {\r\n        text-align: right;\r\n    }\r\n</style>\r\n<table border=\"1\" class=\"dataframe\">\r\n<thead>\r\n<tr style=\"text-align: right;\">\r\n<th>\r\n</th>\r\n<th>\r\n0\r\n</th>\r\n<th>\r\n1\r\n</th>\r\n<th>\r\n2\r\n</th>\r\n<th>\r\n3\r\n</th>\r\n</tr>\r\n</thead>\r\n<tbody>\r\n<tr>\r\n<th>\r\n3\r\n</th>\r\n<td>\r\n12\r\n</td>\r\n<td>\r\n13\r\n</td>\r\n<td>\r\n14\r\n</td>\r\n<td>\r\n15\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>\r\n2\r\n</th>\r\n<td>\r\n8\r\n</td>\r\n<td>\r\n9\r\n</td>\r\n<td>\r\n10\r\n</td>\r\n<td>\r\n11\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>\r\n0\r\n</th>\r\n<td>\r\n0\r\n</td>\r\n<td>\r\n1\r\n</td>\r\n<td>\r\n2\r\n</td>\r\n<td>\r\n3\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>\r\n4\r\n</th>\r\n<td>\r\n16\r\n</td>\r\n<td>\r\n17\r\n</td>\r\n<td>\r\n18\r\n</td>\r\n<td>\r\n19\r\n</td>\r\n</tr>\r\n<tr>\r\n<th>\r\n1\r\n</th>\r\n<td>\r\n4\r\n</td>\r\n<td>\r\n5\r\n</td>\r\n<td>\r\n6\r\n</td>\r\n<td>\r\n7\r\n</td>\r\n</tr>\r\n</tbody>\r\n</table>\r\n</div>\r\n<ul>\r\n<li>合并实现，并只取出3行数据</li>\r\n</ul>\r\n<pre class=\"line-numbers language-python\" data-language=\"python\"><code class=\"language-python\"